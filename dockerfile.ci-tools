FROM python:3.11-slim
 
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
        git \
        grep \
        nodejs \
        npm \
        curl \
    && rm -rf /var/lib/apt/lists/*
 
RUN pip install --no-cache-dir --quiet \
        requests \
        vulture \
        pytest \
        radon \
        pip-audit